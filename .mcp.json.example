{
  "mcpServers": {
    "example-stdio-server": {
      "command": "npx",
      "args": ["-y", "@some/mcp-server"],
      "env": {
        "API_KEY": "<在本地 .mcp.json 填真值，禁止提交真实密钥>"
      }
    },
    "example-http-server": {
      "type": "http",
      "url": "https://mcp.example.com/sse"
    }
  }
}
